generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Method {
  id                    String           @id @default(cuid())
  key                   String           @unique
  categoryKey           String           @default("root-of-equation")
  categoryLabel         String           @default("Root Of Equation")
  categoryOrder         Int              @default(1)
  orderIndex            Int              @default(1)
  title                 String
  description           String
  defaultEquation       String
  equationLabel         String           @default("Equation f(x)")
  primaryInputLabel     String           @default("Primary Input")
  secondaryInputLabel   String?
  secondaryInputNeeded  Boolean          @default(false)
  defaultPrimaryInput   Float            @default(0)
  defaultSecondaryInput Float?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  runs                  ComputationRun[]

  @@index([categoryOrder, orderIndex])
}

model ComputationRun {
  id            String   @id @default(cuid())
  methodId      String
  equation      String
  xl            Float
  xr            Float
  root          Float
  epsilon       Float
  maxIterations Int
  converged     Boolean
  iterations    Json
  createdAt     DateTime @default(now())
  method        Method   @relation(fields: [methodId], references: [id], onDelete: Cascade)

  @@index([methodId, createdAt])
}
