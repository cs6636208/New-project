{
  "name": "numerical-method-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "node ./scripts/prisma-command.mjs generate --schema ../../prisma/schema.prisma",
    "prisma:migrate": "node ./scripts/prisma-command.mjs migrate dev --schema ../../prisma/schema.prisma",
    "prisma:seed": "node ./scripts/prisma-seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mathjs": "^14.3.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
